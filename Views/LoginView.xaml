<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:CobranzaCostas.ViewModels"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    x:Class="CobranzaCostas.Views.LoginView"
    x:DataType="vm:LoginViewModel"
    Shell.NavBarIsVisible="False"
    BackgroundColor="#0D1B2A">

    <ContentPage.Resources>
        <toolkit:InvertedBoolConverter x:Key="InvertedBoolConverter"/>
        <toolkit:IsNotNullOrEmptyConverter x:Key="IsNotEmptyConverter"/>
    </ContentPage.Resources>

    <Grid>
        <ScrollView VerticalOptions="Center">
            <VerticalStackLayout Padding="32,0" Spacing="0">

                <!-- ── Encabezado ───────────────────────────────── -->
                <Label
                    Text="COBRANZA COSTAS"
                    FontSize="24"
                    FontAttributes="Bold"
                    TextColor="#FFD700"
                    HorizontalOptions="Center"
                    CharacterSpacing="2"
                    Margin="0,0,0,4"/>

                <Label
                    Text="División Cobranza Metro Sur"
                    FontSize="13"
                    TextColor="#5588AA"
                    HorizontalOptions="Center"
                    Margin="0,0,0,8"/>

                <Label
                    Text="GCC Zihuatanejo · Acapulco Costas 1"
                    FontSize="11"
                    TextColor="#3A5A7A"
                    HorizontalOptions="Center"
                    Margin="0,0,0,40"/>

                <!-- ── Card de Login ────────────────────────────── -->
                <Border
                    BackgroundColor="#1A2D42"
                    Stroke="#2A4A6A"
                    StrokeThickness="1"
                    Padding="28,32">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="12"/>
                    </Border.StrokeShape>

                    <VerticalStackLayout Spacing="24">

                        <!-- Campo Correo -->
                        <VerticalStackLayout Spacing="8">
                            <Label
                                Text="CORREO ELECTRÓNICO"
                                FontSize="10"
                                FontAttributes="Bold"
                                TextColor="#5588AA"
                                CharacterSpacing="1.5"/>
                            <Entry
                                Text="{Binding Email}"
                                Placeholder="usuario@gcc.com"
                                PlaceholderColor="#2A4A6A"
                                TextColor="White"
                                Keyboard="Email"
                                BackgroundColor="Transparent"
                                FontSize="15"
                                ReturnType="Next"/>
                            <BoxView HeightRequest="1" Color="#2A4A6A"/>
                        </VerticalStackLayout>

                        <!-- Campo Contraseña -->
                        <VerticalStackLayout Spacing="8">
                            <Label
                                Text="CONTRASEÑA"
                                FontSize="10"
                                FontAttributes="Bold"
                                TextColor="#5588AA"
                                CharacterSpacing="1.5"/>
                            <Entry
                                Text="{Binding Password}"
                                Placeholder="••••••••"
                                PlaceholderColor="#2A4A6A"
                                TextColor="White"
                                IsPassword="True"
                                BackgroundColor="Transparent"
                                FontSize="15"
                                ReturnType="Done"
                                ReturnCommand="{Binding LoginCommand}"/>
                            <BoxView HeightRequest="1" Color="#2A4A6A"/>
                        </VerticalStackLayout>

                        <!-- Mensaje de error -->
                        <Label
                            Text="{Binding ErrorMessage}"
                            TextColor="#FF6B6B"
                            FontSize="13"
                            HorizontalTextAlignment="Center"
                            IsVisible="{Binding ErrorMessage, Converter={StaticResource IsNotEmptyConverter}}"/>

                        <!-- Botón Ingresar -->
                        <Button
                            Text="INGRESAR"
                            Command="{Binding LoginCommand}"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}"
                            BackgroundColor="#FFD700"
                            TextColor="#0D1B2A"
                            FontAttributes="Bold"
                            FontSize="14"
                            HeightRequest="50"
                            CornerRadius="8"
                            CharacterSpacing="2"
                            Margin="0,4,0,0"/>

                        <!-- Indicador de carga -->
                        <ActivityIndicator
                            IsRunning="{Binding IsBusy}"
                            IsVisible="{Binding IsBusy}"
                            Color="#FFD700"
                            HorizontalOptions="Center"/>

                    </VerticalStackLayout>
                </Border>

                <!-- ── Footer ───────────────────────────────────── -->
                <Label
                    Text="GCC Zihuatanejo  ·  2026"
                    FontSize="11"
                    TextColor="#2A4A6A"
                    HorizontalOptions="Center"
                    Margin="0,28,0,0"/>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
